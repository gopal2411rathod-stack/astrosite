---
import { industryPages, servicePages, solutionPages } from "../data/catalog";

const columns = [
  {
    title: "Company",
    links: [
      ["About Us", "/about-us/"],
      ["Careers", "/careers/"],
      ["Contact Us", "/contact-us/"],
      ["Portfolio", "/portfolio/"],
      ["Case Studies", "/case-studies/"],
    ],
  },
  {
    title: "Services",
    links: servicePages.map((item) => [item.title, `/services/${item.slug}/`]),
  },
  {
    title: "Solutions",
    links: solutionPages.slice(0, 5).map((item) => [item.title, `/solutions/${item.slug}/`]),
  },
  {
    title: "Industries",
    links: industryPages.slice(0, 5).map((item) => [item.title, `/industries/${item.slug}/`]),
  },
];
---

<footer class="footer">
  <div class="container footer-cta">
    <div>
      <p class="eyebrow">Ready to build</p>
      <h2>Let Hegrix turn your next platform idea into a scalable product.</h2>
    </div>
    <a class="button button-light" href="/contact-us/">Book a free consultation</a>
  </div>

  <div class="container footer-grid">
    <div class="footer-brand">
      <a class="brand footer-logo" href="/">
        <span class="brand-mark">H</span>
        <span class="brand-text">Hegrix</span>
      </a>
      <p>
        Hegrix is a premium software development company building commerce, ERP, CRM,
        AI automation and mobile platforms for ambitious businesses.
      </p>
      <form
        class="newsletter"
        action="mailto:gopal2411rathod@gmail.com?subject=Newsletter%20subscription"
        method="post"
        enctype="text/plain"
        aria-label="Newsletter subscription"
      >
        <label for="newsletter-email">Get practical digital growth insights</label>
        <div>
          <input id="newsletter-email" name="email" type="email" placeholder="you@company.com" required />
          <button type="submit">Subscribe</button>
        </div>
      </form>
    </div>

    {columns.map((column) => (
      <div class="footer-column">
        <h3>{column.title}</h3>
        {column.links.map(([label, href]) => <a href={href}>{label}</a>)}
      </div>
    ))}
    <div class="footer-column">
      <h3>Resources</h3>
      <a href="/blog/">Blog</a>
      <a href="/faq/">FAQ</a>
      <a href="/privacy-policy/">Privacy Policy</a>
      <a href="/terms-and-conditions/">Terms &amp; Conditions</a>
      <a href="/sitemap.xml">Sitemap</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>Contact: <a href="mailto:gopal2411rathod@gmail.com">gopal2411rathod@gmail.com</a> | +91 82384 56194</p>
    <p>
      <a href="https://www.linkedin.com/company/hegrix">LinkedIn</a>
      <a href="https://x.com/hegrix">X</a>
      <a href="https://www.youtube.com/@hegrix">YouTube</a>
    </p>
    <p>Copyright {new Date().getFullYear()} Hegrix. All rights reserved.</p>
  </div>
</footer>
