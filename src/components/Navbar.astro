<script>
  const button = document.getElementById("menu-button");
  const menu = document.getElementById("mobile-menu");
  const megaGroups = document.querySelectorAll(".service-mega-group");

  button?.addEventListener("click", () => {
    const isOpen = button.getAttribute("aria-expanded") === "true";
    button.setAttribute("aria-expanded", String(!isOpen));
    menu?.classList.toggle("is-open", !isOpen);
  });

  megaGroups.forEach((group) => {
    const trigger = group.querySelector(":scope > a");
    const categories = group.querySelectorAll("[data-mega-category]");
    const panels = group.querySelectorAll("[data-mega-panel]");

    const activateCategory = (index) => {
      categories.forEach((category) => {
        const isActive = category.getAttribute("data-mega-category") === index;
        category.classList.toggle("is-active", isActive);
        category.setAttribute("aria-selected", String(isActive));
      });

      panels.forEach((panel) => {
        const isActive = panel.getAttribute("data-mega-panel") === index;
        panel.classList.toggle("is-active", isActive);
        panel.setAttribute("aria-hidden", String(!isActive));
      });
    };

    categories.forEach((category) => {
      const index = category.getAttribute("data-mega-category");
      category.addEventListener("mouseenter", () => activateCategory(index));
      category.addEventListener("focus", () => activateCategory(index));
      category.addEventListener("click", () => activateCategory(index));
      category.addEventListener("keydown", (event) => {
        if (event.key !== "ArrowDown" && event.key !== "ArrowUp") {
          return;
        }

        event.preventDefault();
        const current = Array.from(categories).indexOf(category);
        const next =
          event.key === "ArrowDown"
            ? (current + 1) % categories.length
            : (current - 1 + categories.length) % categories.length;
        categories[next]?.focus();
      });
    });

    group.addEventListener("mouseenter", () => trigger?.setAttribute("aria-expanded", "true"));
    group.addEventListener("mouseleave", () => trigger?.setAttribute("aria-expanded", "false"));
    group.addEventListener("focusin", () => trigger?.setAttribute("aria-expanded", "true"));
    group.addEventListener("focusout", (event) => {
      if (!group.contains(event.relatedTarget)) {
        trigger?.setAttribute("aria-expanded", "false");
      }
    });
  });
</script>
