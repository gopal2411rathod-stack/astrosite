const serviceHref = (service: string) => {
  const match = servicePages.find((page) => page.title.toLowerCase() === service.toLowerCase());
  return match ? `/services/${match.slug}/` : `/contact-us/?service=${encodeURIComponent(service)}`;
};
const solutionHref = (service: string) => {
  const match = solutionPages.find((solution) => solution.title.toLowerCase() === service.toLowerCase());
  return match ? `/solutions/${match.slug}/` : `/contact-us/?solution=${encodeURIComponent(service)}`;
};
const industryHref = (service: string) => {
  const industrySlugMap: Record<string, string> = {
    automobile: "automobile",
    automotive: "automotive",
    manufacturing: "manufacturing",
    logistics: "logistics",
    "real estate": "real-estate",
    retail: "retail",
    healthcare: "healthcare",
    finance: "finance",
    education: "education",
    "travel & hospitality": "travel-hospitality",
    "diamond & jewelry": "diamond-jewelry",
    "media & entertainment": "media-entertainment",
    advertising: "advertising",
  };
  const normalized = service.toLowerCase().replace(/\s+software solutions$/, "");
  const directSlug = industrySlugMap[normalized];
  if (directSlug) {
    return `/industries/${directSlug}/`;
  }
  const match = industryPages.find((industry) => industry.title.toLowerCase() === service.toLowerCase());
  return match ? `/industries/${match.slug}/` : `/contact-us/?industry=${encodeURIComponent(service)}`;
};
