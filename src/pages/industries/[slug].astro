---
import Layout from "../../layouts/Layout.astro";
import SeoPage from "../../components/SeoPage.astro";
import { industryPages } from "../../data/catalog";

export const prerender = true;

export function getStaticPaths() {
  return industryPages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const isAutomotive = page.slug === "automotive";
const isManufacturing = page.slug === "manufacturing";

const sections = [
  {
    eyebrow: "Industry detail",
    title: `${page.title} built around real workflows.`,
    text: page.description,
    cards: [
      { title: "Customer Experience", text: "Design buying, booking, ordering or service journeys that are clear and conversion-focused." },
      { title: "Operations", text: "Connect teams, inventory, documents, reporting and approvals with practical digital workflows." },
      { title: "Scalable Technology", text: "Use secure, fast and maintainable architecture that supports industry-specific growth." },
    ],
  },
  {
    eyebrow: "Related services",
    title: "Match industry needs with the right Hegrix capabilities.",
    text: "Common fits include custom software, ecommerce, marketplaces, ERP and CRM, AI automation, portals and cloud infrastructure.",
  },
];

const automotiveChallenges = [
  "Complex supply chains",
  "Thousands of spare parts and components",
  "Production scheduling delays",
  "Inventory shortages or excess stock",
  "Quality and compliance pressure",
  "Manual procurement processes",
  "Limited real-time operational visibility",
  "Warranty and service complexity",
  "Demand forecasting gaps",
  "Rising operating costs",
];

const automotiveCapabilities = [
  { title: "Production Planning", text: "Manage manufacturing orders, bills of materials, routing, work centers and production schedules." },
  { title: "Inventory Management", text: "Track raw materials, spare parts, finished goods and warehouse stock in real time." },
  { title: "Procurement Management", text: "Automate purchase requests, quotations, approvals and purchase orders to keep production moving." },
  { title: "Supplier Management", text: "Monitor supplier performance, delivery schedules, pricing and quality metrics from one dashboard." },
  { title: "Quality Control", text: "Add inspection checkpoints across manufacturing to support consistent quality and compliance." },
  { title: "Sales Management", text: "Handle quotations, orders, invoices, dealer pricing and customer relationships in one platform." },
  { title: "Warehouse Management", text: "Improve warehouse accuracy with barcode support, transfers, batch tracking and location visibility." },
  { title: "Maintenance Management", text: "Schedule preventive maintenance for machinery and equipment to reduce downtime." },
  { title: "Accounting & Finance", text: "Manage payables, receivables, taxation, budgets, reporting and cash flow with better visibility." },
  { title: "CRM", text: "Track leads, inquiries, opportunities and after-sales support to strengthen customer relationships." },
  { title: "Analytics & Dashboards", text: "See sales, inventory, production, procurement, profitability and operations in real time." },
];

const automotiveBenefits = [
  "Increase production efficiency",
  "Reduce operational costs",
  "Improve inventory accuracy",
  "Enhance supply chain visibility",
  "Accelerate procurement processes",
  "Improve customer satisfaction",
  "Reduce production downtime",
  "Support quality compliance",
  "Enable data-driven decisions",
  "Scale operations with confidence",
];

const automotiveAudiences = [
  "Automotive Manufacturers",
  "Auto Parts Manufacturers",
  "Spare Parts Distributors",
  "Vehicle Dealerships",
  "Auto Component Suppliers",
  "Service & Repair Centers",
  "Fleet Management Companies",
  "Automotive Equipment Manufacturers",
];

const automotiveServices = [
  "ERP Consulting",
  "Business Process Analysis",
  "ERP Implementation",
  "Module Customization",
  "Data Migration",
  "Third-Party Integrations",
  "User Training",
  "Ongoing Technical Support",
  "Performance Optimization",
];

const automotiveFaq = [
  {
    title: "What is Automotive ERP?",
    text: "Automotive ERP is an integrated business management system that connects manufacturing, inventory, procurement, finance, sales, quality control and customer management into a single platform.",
  },
  {
    title: "Can the ERP be customized?",
    text: "Yes. The solution can be tailored to your workflows, approval processes, reporting requirements and industry-specific operations.",
  },
  {
    title: "Does it support multiple warehouses?",
    text: "Yes. You can manage multiple warehouses, locations, stock transfers and inventory movements from a centralized system.",
  },
  {
    title: "Can it integrate with existing software?",
    text: "Yes. The ERP can integrate with accounting systems, ecommerce platforms, payment gateways, logistics providers, CRM tools and other third-party applications.",
  },
  {
    title: "Is the solution cloud-based?",
    text: "Yes. Hegrix can support cloud-hosted and on-premise deployment options based on business requirements.",
  },
  {
    title: "Do you provide implementation and support?",
    text: "Yes. Hegrix provides implementation, training, customization and ongoing support to help teams adopt the ERP successfully.",
  },
];

const automotiveSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Automotive ERP Software Solutions",
    provider: {
      "@type": "Organization",
      name: "Hegrix",
      url: "https://hegrix.com",
    },
    areaServed: "Global",
    serviceType: "Automotive ERP implementation and customization",
    description: "ERP software solutions for automotive manufacturers, auto parts suppliers, dealerships, distributors and service centers.",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: automotiveFaq.map((item) => ({
      "@type": "Question",
      name: item.title,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.text,
      },
    })),
  },
];

const manufacturingChallenges = [
  "Manual production planning",
  "Limited shop floor visibility",
  "Raw material shortages",
  "Excess inventory and carrying costs",
  "Supplier delivery delays",
  "Quality inspection gaps",
  "Disconnected finance and operations",
  "Machine downtime and maintenance issues",
  "Slow order tracking",
  "Inaccurate production costing",
];

const manufacturingCapabilities = [
  { title: "Production Planning", text: "Plan jobs, capacity, work orders, routings and schedules with clearer control over production flow." },
  { title: "MRP & BOM Management", text: "Manage bills of materials, material requirements, component availability and production dependencies." },
  { title: "Inventory Control", text: "Track raw materials, WIP, finished goods, stock movements and reorder levels across locations." },
  { title: "Shop Floor Tracking", text: "Monitor job progress, machine activity, labor usage and production status from real-time dashboards." },
  { title: "Quality Management", text: "Create inspection workflows, non-conformance tracking, approvals and quality records for compliance." },
  { title: "Procurement Automation", text: "Automate purchase requests, supplier quotations, approvals and purchase orders." },
  { title: "Supplier Management", text: "Track vendor performance, lead times, pricing, delivery reliability and quality scores." },
  { title: "Warehouse Management", text: "Improve receiving, picking, transfers, barcode workflows and inventory accuracy." },
  { title: "Maintenance Management", text: "Schedule preventive maintenance, track breakdowns and reduce equipment downtime." },
  { title: "Costing & Finance", text: "Connect production costs, purchasing, inventory valuation, invoices and financial reporting." },
  { title: "Analytics & BI", text: "Measure output, downtime, scrap, margins, order status, inventory health and supplier performance." },
  { title: "Customer & Order Management", text: "Manage quotes, sales orders, delivery commitments and customer communication in one flow." },
];

const manufacturingBenefits = [
  "Improve production efficiency",
  "Reduce material waste",
  "Increase inventory accuracy",
  "Improve on-time delivery",
  "Strengthen quality compliance",
  "Reduce machine downtime",
  "Connect finance and operations",
  "Improve supplier accountability",
  "Enable real-time decision-making",
  "Scale manufacturing operations confidently",
];

const manufacturingAudiences = [
  "Discrete Manufacturers",
  "Process Manufacturers",
  "Industrial Equipment Manufacturers",
  "Consumer Goods Manufacturers",
  "Electronics Manufacturers",
  "Textile & Apparel Manufacturers",
  "Packaging Manufacturers",
  "Fabrication & Assembly Units",
];

const manufacturingServices = [
  "Manufacturing ERP Consulting",
  "Process Mapping",
  "ERP Implementation",
  "MRP and BOM Setup",
  "Shop Floor Workflow Design",
  "Inventory Migration",
  "Third-Party Integrations",
  "User Training",
  "Reporting and Dashboard Setup",
];

const manufacturingFaq = [
  {
    title: "What is manufacturing software?",
    text: "Manufacturing software helps companies manage production planning, inventory, purchasing, quality, maintenance, costing, orders and reporting from one connected system.",
  },
  {
    title: "Can manufacturing ERP be customized?",
    text: "Yes. Hegrix can customize workflows, approvals, BOM logic, production stages, quality checks, dashboards and integrations around your manufacturing process.",
  },
  {
    title: "Does it support inventory and warehouse management?",
    text: "Yes. Manufacturing software can track raw materials, WIP, finished goods, warehouses, stock transfers, barcode workflows and reorder levels.",
  },
  {
    title: "Can it help with production planning?",
    text: "Yes. The system can support production schedules, work orders, capacity planning, routings, material requirements and job progress tracking.",
  },
  {
    title: "Can it integrate with accounting or ecommerce tools?",
    text: "Yes. Hegrix can integrate manufacturing workflows with accounting systems, CRM tools, ecommerce platforms, logistics providers and analytics tools.",
  },
  {
    title: "Do you provide implementation and support?",
    text: "Yes. Hegrix provides consulting, implementation, customization, data migration, user training and ongoing technical support.",
  },
];

const manufacturingSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Manufacturing Software Solutions",
    provider: {
      "@type": "Organization",
      name: "Hegrix",
      url: "https://hegrix.com",
    },
    areaServed: "Global",
    serviceType: "Manufacturing ERP and production management software",
    description: "Manufacturing software solutions for production planning, MRP, BOM, inventory, shop floor tracking, quality, maintenance, finance and analytics.",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: manufacturingFaq.map((item) => ({
      "@type": "Question",
      name: item.title,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.text,
      },
    })),
  },
];
---

{isAutomotive ? (
  <Layout
    title="Automotive ERP Software Solutions | Hegrix"
    description="Modern Automotive ERP software for manufacturers, auto parts suppliers, dealerships, distributors and service centers."
    keywords="automotive ERP software solutions, automotive ERP, auto parts ERP, dealership ERP, automotive manufacturing ERP"
    path="/industries/automotive/"
    schema={automotiveSchema}
  >
    <section class="automotive-hero">
      <div class="container automotive-hero__grid">
        <div>
          <p class="eyebrow">Automotive ERP Software Solutions</p>
          <h1>Transform your automotive business with an intelligent ERP solution.</h1>
          <p class="lead">
            Drive operational excellence with a connected ERP platform for manufacturers, auto parts suppliers,
            dealerships, distributors and service centers.
          </p>
          <p class="automotive-hero__copy">
            Streamline production, optimize inventory, improve supply chain visibility and deliver better customer
            experiences from one integrated operating system.
          </p>
          <div class="hero-actions">
            <a class="button" href="/contact-us/">Book a free consultation</a>
            <a class="button button-ghost" href="#features">Explore features</a>
          </div>
        </div>
        <div class="erp-visual" aria-label="Automotive ERP dashboard preview">
          <div class="erp-visual__top">
            <span>ERP Command Center</span>
            <strong>Live</strong>
          </div>
          <div class="erp-visual__metrics">
            <div><strong>98%</strong><span>Inventory accuracy</span></div>
            <div><strong>24/7</strong><span>Operational visibility</span></div>
            <div><strong>11</strong><span>Core modules</span></div>
          </div>
          <div class="erp-flow">
            <span>Procurement</span>
            <span>Production</span>
            <span>Warehouse</span>
            <span>Sales</span>
          </div>
          <div class="erp-visual__panel">
            <p>Production schedule</p>
            <div class="visual-bars"><span></span><span></span><span></span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container split-band">
        <div class="section-heading">
          <p class="eyebrow">Industry challenges</p>
          <h2>Automotive operations move fast, and disconnected systems slow everything down.</h2>
          <p>
            Without an integrated ERP, production, procurement, inventory, finance and service teams often work from
            separate data, creating delays, cost leakage and missed decisions.
          </p>
        </div>
        <div class="check-grid">
          {automotiveChallenges.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </section>

    <section class="section soft-section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Our solution</p>
          <h2>Centralize every aspect of automotive operations.</h2>
          <p>
            Hegrix helps you connect inventory, production, purchasing, sales, warehouses, quality, maintenance,
            accounting, CRM and analytics with real-time dashboards and automated workflows.
          </p>
        </div>
        <div class="stats-grid">
          <div class="stat-card"><strong>ERP</strong><span>One connected operating platform</span></div>
          <div class="stat-card"><strong>BOM</strong><span>Manufacturing orders and routing</span></div>
          <div class="stat-card"><strong>CRM</strong><span>Lead, sales and service lifecycle</span></div>
          <div class="stat-card"><strong>BI</strong><span>Real-time reporting and decisions</span></div>
        </div>
      </div>
    </section>

    <section class="section" id="features">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Industry-specific features</p>
          <h2>ERP modules built around automotive workflows.</h2>
          <p>
            Choose the capabilities that match your operation, then tailor approvals, reports, integrations and roles
            around how your team works.
          </p>
        </div>
        <div class="card-grid automotive-feature-grid">
          {automotiveCapabilities.map((card) => (
            <article class="feature-card">
              <span class="card-icon" aria-hidden="true">{card.title.slice(0, 1)}</span>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section soft-section">
      <div class="container split-band">
        <div class="section-heading">
          <p class="eyebrow">Business benefits</p>
          <h2>Improve control, speed and visibility across the automotive value chain.</h2>
          <p>
            The right ERP reduces manual work, improves inventory confidence, keeps production aligned and gives leaders
            a clearer view of cost, quality and performance.
          </p>
          <div class="hero-actions">
            <a class="button" href="/contact-us/">Talk to an ERP expert</a>
          </div>
        </div>
        <div class="check-grid">
          {automotiveBenefits.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container two-column-lists">
        <div>
          <div class="section-heading">
            <p class="eyebrow">Who can benefit?</p>
            <h2>Built for automotive businesses with operational complexity.</h2>
          </div>
          <div class="check-grid compact">
            {automotiveAudiences.map((item) => <span>{item}</span>)}
          </div>
        </div>
        <div>
          <div class="section-heading">
            <p class="eyebrow">Implementation services</p>
            <h2>Guidance from planning through adoption.</h2>
          </div>
          <div class="check-grid compact">
            {automotiveServices.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </div>
    </section>

    <section class="section soft-section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">FAQ</p>
          <h2>Frequently asked questions</h2>
          <p>Clear answers before you plan your Automotive ERP implementation.</p>
        </div>
        <div class="faq-list">
          {automotiveFaq.map((item) => (
            <details>
              <summary>{item.title}</summary>
              <p>{item.text}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section final-cta">
      <div class="container split-cta">
        <div>
          <p class="eyebrow">Get started</p>
          <h2>Empower your automotive business with modern ERP.</h2>
          <p>Book a free consultation and discover how Hegrix can streamline operations and support long-term growth.</p>
        </div>
        <a class="button button-light" href="/contact-us/">Book a consultation</a>
      </div>
    </section>
  </Layout>
) : isManufacturing ? (
  <Layout
    title="Manufacturing Software Solutions | ERP, MRP & Production Management | Hegrix"
    description="Manufacturing software solutions for ERP, MRP, production planning, inventory, quality control, shop floor tracking, supplier management and analytics."
    keywords="manufacturing software solutions, manufacturing ERP software, production management software, MRP software, inventory management for manufacturing"
    path="/industries/manufacturing/"
    schema={manufacturingSchema}
  >
    <section class="automotive-hero industry-hero manufacturing-hero">
      <div class="container automotive-hero__grid industry-hero__grid">
        <div>
          <p class="eyebrow">Manufacturing Software Solutions</p>
          <h1>Build a smarter, faster and more connected manufacturing operation.</h1>
          <p class="lead">
            Hegrix designs manufacturing ERP and production management systems that connect planning, inventory,
            procurement, shop floor activity, quality, maintenance, finance and analytics.
          </p>
          <p class="automotive-hero__copy industry-hero__copy">
            Replace disconnected spreadsheets and manual follow-ups with real-time manufacturing visibility, automated
            workflows and reliable data for better decisions.
          </p>
          <div class="hero-actions">
            <a class="button" href="/contact-us/">Get a manufacturing ERP consultation</a>
            <a class="button button-ghost" href="#manufacturing-features">View capabilities</a>
          </div>
        </div>
        <div class="erp-visual manufacturing-visual" aria-label="Manufacturing software dashboard preview">
          <div class="erp-visual__top">
            <span>Factory Operations Hub</span>
            <strong>Live</strong>
          </div>
          <div class="erp-visual__metrics">
            <div><strong>MRP</strong><span>Material planning</span></div>
            <div><strong>OEE</strong><span>Shop floor visibility</span></div>
            <div><strong>QC</strong><span>Quality checkpoints</span></div>
          </div>
          <div class="erp-flow">
            <span>Plan</span>
            <span>Procure</span>
            <span>Produce</span>
            <span>Deliver</span>
          </div>
          <div class="erp-visual__panel">
            <p>Production performance</p>
            <div class="visual-bars"><span></span><span></span><span></span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container split-band">
        <div class="section-heading">
          <p class="eyebrow">Manufacturing challenges</p>
          <h2>Growth gets harder when production, inventory and finance are not connected.</h2>
          <p>
            Manufacturing teams need accurate material data, reliable schedules, quality visibility and clear cost
            tracking. When these workflows live in separate tools, delays and waste become expensive.
          </p>
        </div>
        <div class="check-grid">
          {manufacturingChallenges.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </section>

    <section class="section soft-section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Connected manufacturing platform</p>
          <h2>Control production from quote to delivery.</h2>
          <p>
            Hegrix builds manufacturing software that gives teams one operating view across work orders, BOMs,
            inventory, suppliers, quality checks, maintenance tasks, costing and reports.
          </p>
        </div>
        <div class="stats-grid">
          <div class="stat-card"><strong>MRP</strong><span>Material planning and BOM control</span></div>
          <div class="stat-card"><strong>WIP</strong><span>Work-in-progress tracking</span></div>
          <div class="stat-card"><strong>QC</strong><span>Inspection and compliance records</span></div>
          <div class="stat-card"><strong>BI</strong><span>Production and cost analytics</span></div>
        </div>
      </div>
    </section>

    <section class="section" id="manufacturing-features">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Manufacturing software capabilities</p>
          <h2>Everything needed to plan, produce, track and improve.</h2>
          <p>
            Select the modules your operation needs now, then extend into deeper automation, integrations and analytics
            as the business grows.
          </p>
        </div>
        <div class="card-grid automotive-feature-grid">
          {manufacturingCapabilities.map((card) => (
            <article class="feature-card">
              <span class="card-icon" aria-hidden="true">{card.title.slice(0, 1)}</span>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section soft-section">
      <div class="container split-band">
        <div class="section-heading">
          <p class="eyebrow">Business outcomes</p>
          <h2>Turn operational data into better production decisions.</h2>
          <p>
            Manufacturing software should do more than store records. It should help teams reduce waste, improve
            delivery performance, protect margins and act before small problems become production delays.
          </p>
          <div class="hero-actions">
            <a class="button" href="/contact-us/">Plan your manufacturing system</a>
          </div>
        </div>
        <div class="check-grid">
          {manufacturingBenefits.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container two-column-lists">
        <div>
          <div class="section-heading">
            <p class="eyebrow">Who it is for</p>
            <h2>Manufacturing software for teams that need control and scale.</h2>
          </div>
          <div class="check-grid compact">
            {manufacturingAudiences.map((item) => <span>{item}</span>)}
          </div>
        </div>
        <div>
          <div class="section-heading">
            <p class="eyebrow">Implementation services</p>
            <h2>From workflow discovery to rollout and support.</h2>
          </div>
          <div class="check-grid compact">
            {manufacturingServices.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </div>
    </section>

    <section class="section soft-section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">FAQ</p>
          <h2>Manufacturing software questions</h2>
          <p>Useful answers before you modernize production workflows.</p>
        </div>
        <div class="faq-list">
          {manufacturingFaq.map((item) => (
            <details>
              <summary>{item.title}</summary>
              <p>{item.text}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section final-cta">
      <div class="container split-cta">
        <div>
          <p class="eyebrow">Next step</p>
          <h2>Ready to modernize manufacturing operations?</h2>
          <p>Share your production workflow and Hegrix will map the right ERP, MRP, inventory and reporting path.</p>
        </div>
        <a class="button button-light" href="/contact-us/">Book a consultation</a>
      </div>
    </section>
  </Layout>
) : (
  <SeoPage
    title={`${page.title} | Hegrix`}
    description={`${page.description} Hegrix builds industry-specific software with premium UX, SEO-friendly structure and scalable engineering.`}
    keywords={`${page.keyword}, Hegrix, industry software development`}
    path={`/industries/${page.slug}/`}
    eyebrow="Hegrix Industry"
    h1={page.title}
    intro={`${page.description} Hegrix creates digital platforms that fit your industry, customers and operational reality.`}
    sections={sections}
  />
)}

