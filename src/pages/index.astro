---
import Layout from "../layouts/Layout.astro";

const services = [
  ["Custom Software Development", "Plan, design and build secure platforms tailored to your workflows, users and growth targets."],
  ["eCommerce Development", "Launch high-converting storefronts, B2B portals and headless commerce experiences with clean operations behind them."],
  ["Marketplace Development", "Create vendor onboarding, product catalogs, commissions, fulfillment and dashboards for multi-sided businesses."],
  ["ERP & CRM Development", "Connect teams, customers, inventory, finance and reporting through practical ERP and CRM systems."],
  ["AI & Automation", "Automate repetitive work, knowledge retrieval, document processing and internal decision support with responsible AI."],
  ["Cloud & DevOps", "Ship reliable applications with scalable infrastructure, observability, CI/CD and performance monitoring."],
];

const solutions = [
  ["B2B Commerce", "Quote workflows, bulk ordering, negotiated pricing and account-level buying experiences."],
  ["Inventory & POS", "Real-time stock, purchasing, barcode workflows and retail operations in one system."],
  ["Customer Portals", "Self-service dashboards for orders, tickets, invoices, documents and project visibility."],
];

const industries = ["Retail", "Automotive", "Manufacturing", "Healthcare", "Logistics", "Real Estate"];
const tech = ["Astro", "React", "Next.js", "Node.js", "Laravel", "Python", "Odoo", "Shopify", "AWS", "PostgreSQL"];
const process = ["Discover", "Plan", "Design", "Build", "Test", "Launch", "Optimize"];
const faqs = [
  ["How quickly can Hegrix start?", "Most discovery calls can be scheduled within two business days. After scope alignment, the delivery team can usually begin within one to two weeks."],
  ["Do you provide SEO-friendly development?", "Yes. Hegrix builds semantic pages, clean URLs, structured metadata, fast layouts and accessible components from the start."],
  ["Can you modernize an existing system?", "Yes. We can audit your current platform, prioritize risks and migrate in stages so the business keeps moving."],
];
const blogs = [
  ["How to Plan a Scalable B2B Commerce Platform", "/blog/"],
  ["ERP Integration Mistakes That Slow Growing Teams", "/blog/"],
  ["Where AI Automation Creates the Fastest Business Value", "/blog/"],
];
---

<Layout
  title="Hegrix | Custom Software, Commerce, AI and ERP Development Company"
  description="Hegrix builds premium custom software, ecommerce platforms, marketplaces, ERP, CRM, AI automation and mobile apps for growth-focused businesses."
  keywords="Hegrix, custom software development company, ecommerce development, marketplace development, AI automation, ERP CRM development"
  path="/"
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Premium software development company</p>
        <h1>Digital platforms engineered for growth, automation and scale.</h1>
        <p class="lead">
          Hegrix designs and develops high-performance ecommerce, marketplace, ERP,
          CRM, AI automation and mobile solutions for businesses that need more than
          a template.
        </p>
        <div class="hero-actions">
          <a class="button" href="/contact-us/">Get a Quote</a>
          <a class="button button-ghost" href="/portfolio/">View Our Work</a>
        </div>
        <div class="trust-row" aria-label="Trust signals">
          <span class="trust-pill">Free consultation</span>
          <span class="trust-pill">NDA available</span>
          <span class="trust-pill">SEO-ready delivery</span>
        </div>
      </div>

      <div class="platform-visual" aria-label="Hegrix platform dashboard illustration">
        <div class="dashboard-card">
          <p>Commerce command center</p>
          <div class="visual-bars"><span></span><span></span><span></span></div>
        </div>
        <div class="metric-row">
          <div class="metric"><strong>98%</strong><span>Launch quality</span></div>
          <div class="metric"><strong>42%</strong><span>Faster ops</span></div>
          <div class="metric"><strong>24/7</strong><span>Monitoring</span></div>
        </div>
        <div class="dashboard-card">
          <p>AI workflow active</p>
          <div class="visual-bars"><span></span><span></span><span></span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Trusted by ambitious teams</p>
        <h2>Built for companies that value reliability, clarity and measurable outcomes.</h2>
      </div>
      <div class="logo-cloud" aria-label="Representative client categories">
        <span>Retail</span><span>SaaS</span><span>Health</span><span>Auto</span><span>ERP</span><span>AI</span>
      </div>
    </div>
  </section>

  <section class="section soft-section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Services</p>
        <h2>Everything needed to plan, build and grow a serious digital platform.</h2>
        <p>Each service is designed around business outcomes, clean architecture and long-term maintainability.</p>
      </div>
      <div class="card-grid">
        {services.map(([title, text]) => (
          <article class="feature-card">
            <span class="card-icon" aria-hidden="true">{title.slice(0, 1)}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-band">
      <div class="section-heading">
        <p class="eyebrow">Solutions</p>
        <h2>Business software shaped around the way your team sells, serves and operates.</h2>
        <p>Hegrix connects customer experience with internal operations so growth does not create chaos.</p>
        <div class="hero-actions"><a class="button" href="/solutions/">Explore Solutions</a></div>
      </div>
      <div class="card-grid">
        {solutions.map(([title, text]) => (
          <article class="feature-card">
            <span class="card-icon" aria-hidden="true">{title.slice(0, 1)}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft-section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Why choose Hegrix</p>
        <h2>Senior thinking, conversion-aware design and dependable engineering in one team.</h2>
      </div>
      <div class="stats-grid">
        <div class="stat-card"><strong>120+</strong><span>Projects planned and delivered</span></div>
        <div class="stat-card"><strong>12+</strong><span>Industries supported</span></div>
        <div class="stat-card"><strong>35+</strong><span>Product and engineering specialists</span></div>
        <div class="stat-card"><strong>98%</strong><span>Client satisfaction target</span></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Industries we serve</p>
        <h2>Practical platforms for industries with real operational complexity.</h2>
      </div>
      <div class="card-grid">
        {industries.map((industry) => (
          <a class="feature-card" href="/industries/">
            <span class="card-icon" aria-hidden="true">{industry.slice(0, 1)}</span>
            <h3>{industry}</h3>
            <p>Digital systems tailored to the workflows, buying journeys and reporting needs of {industry.toLowerCase()} teams.</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft-section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Portfolio</p>
        <h2>Selected project patterns Hegrix can deliver.</h2>
      </div>
      <div class="card-grid">
        <article class="case-card"><h3>B2B Ordering Portal</h3><p>Account pricing, quote approval, inventory visibility and self-service ordering for sales teams.</p></article>
        <article class="case-card"><h3>AI Document Workflow</h3><p>OCR extraction, approval queues and ERP posting to reduce manual finance operations.</p></article>
        <article class="case-card"><h3>Marketplace Operations Hub</h3><p>Vendor onboarding, catalog controls, commission tracking and customer dashboards.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-band">
      <div class="section-heading">
        <p class="eyebrow">Technologies</p>
        <h2>Modern tools chosen for performance, security and maintainability.</h2>
        <p>We select platforms based on the product strategy, not trends alone.</p>
      </div>
      <div class="logo-cloud">
        {tech.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </section>

  <section class="section soft-section">
    <div class="container split-band">
      <div class="section-heading">
        <p class="eyebrow">Process</p>
        <h2>A clear delivery path from idea to launch and ongoing optimization.</h2>
      </div>
      <div class="process-list">
        {process.map((item, index) => (
          <div class="process-item">
            <span>{index + 1}</span>
            <div><h3>{item}</h3><p>Structured collaboration keeps scope, quality and timelines visible.</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Client testimonials</p>
        <h2>Trust is built through thoughtful communication and dependable delivery.</h2>
      </div>
      <div class="card-grid">
        <article class="testimonial-card"><p>"Hegrix brought structure to our roadmap and helped us launch a cleaner customer experience."</p><h3>Operations Director</h3></article>
        <article class="testimonial-card"><p>"Their team translated a complex workflow into software our staff actually wanted to use."</p><h3>Retail Founder</h3></article>
        <article class="testimonial-card"><p>"Performance, SEO and maintainability were considered from day one."</p><h3>Marketing Lead</h3></article>
      </div>
    </div>
  </section>

  <section class="section soft-section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">FAQs</p>
        <h2>Useful answers for project owners.</h2>
      </div>
      <div class="faq-list">
        {faqs.map(([title, text]) => (
          <details>
            <summary>{title}</summary>
            <p>{text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Latest blogs</p>
        <h2>Insights for better digital decisions.</h2>
      </div>
      <div class="card-grid">
        {blogs.map(([title, href]) => (
          <a class="blog-card" href={href}>
            <h3>{title}</h3>
            <p>Read practical guidance from the Hegrix team.</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container split-cta">
      <div>
        <p class="eyebrow">Contact CTA</p>
        <h2>Have a platform idea, bottleneck or modernization goal?</h2>
        <p>Book a free consultation and get a clear next-step plan from Hegrix.</p>
      </div>
      <a class="button button-light" href="/contact-us/">Get a Quote</a>
    </div>
  </section>
</Layout>
