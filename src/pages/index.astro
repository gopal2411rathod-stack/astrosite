---
import Layout from "../layouts/Layout.astro";

const modules = [
  { code: "SOL-01", type: "Solution", name: "Automotive Software", desc: "Service bays, sales, and inventory in one system.", href: "/solutions/automotive" },
  { code: "SOL-02", type: "Solution", name: "Autoparts Software", desc: "Catalog, price, and move parts without guesswork.", href: "/solutions/autoparts" },
  { code: "SOL-03", type: "Solution", name: "Hardware Store Software", desc: "Point of sale and stock control built for hardware retail.", href: "/solutions/hardware-store" },
  { code: "SVC-01", type: "Service", name: "Odoo Service", desc: "Implementation, customization, and support for Odoo.", href: "/services/odoo" },
  { code: "SVC-02", type: "Service", name: "Shopify Service", desc: "Storefront build, migration, and ongoing Shopify support.", href: "/services/shopify" },
];
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">Retail & Service Software</p>
        <h1>Built for the parts you sell<br />and the systems you run on.</h1>
        <p class="hero-sub">
          Purpose-built software for automotive, autoparts, and hardware retail -
          plus hands-on Odoo and Shopify implementation when you need a partner, not just a platform.
        </p>
        <div class="hero-actions">
          <a href="/contact" class="btn-primary">Talk to us</a>
          <a href="#directory" class="btn-secondary">View the directory</a>
        </div>
      </div>

      <div class="hero-panel" aria-hidden="true">
        <p class="panel-label">Live status</p>
        <div class="panel-row"><span>Inventory sync</span><span class="dot dot-on"></span></div>
        <div class="panel-row"><span>POS terminals</span><span class="dot dot-on"></span></div>
        <div class="panel-row"><span>Storefront</span><span class="dot dot-on"></span></div>
        <div class="panel-row"><span>Support queue</span><span class="dot dot-idle"></span></div>
      </div>
    </div>
  </section>

  <!-- Module directory: the signature element, doubles as a real index -->
  <section class="directory" id="directory">
    <div class="wrap">
      <p class="eyebrow">Directory</p>
      <h2>Solutions and services, indexed.</h2>

      <div class="directory-grid">
        {modules.map((m) => (
          <a class="module-card" href={m.href}>
            <div class="module-top">
              <span class="module-code">{m.code}</span>
              <span class="module-type">{m.type}</span>
            </div>
            <h3 class="module-name">{m.name}</h3>
            <p class="module-desc">{m.desc}</p>
            <span class="module-arrow" aria-hidden="true">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="wrap cta-inner">
      <div>
        <p class="eyebrow">Get started</p>
        <h2>Tell us what you run today.</h2>
      </div>
      <a href="/contact" class="btn-primary">Talk to us</a>
    </div>
  </section>

  <footer class="site-footer">
    <div class="wrap footer-inner">
      <span>&copy; {new Date().getFullYear()} YourCompany</span>
      <span class="footer-links">
        <a href="/contact">Contact</a>
      </span>
    </div>
  </footer>
</Layout>

<style>
  /* Hero */
  .hero {
    background: var(--ink);
    color: var(--paper);
  }

  .hero-inner {
    padding: 88px 32px 96px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 48px;
    align-items: center;
  }

  .hero-copy h1 {
    font-size: clamp(2.1rem, 4vw, 3.2rem);
    margin: 18px 0 24px;
    color: var(--paper);
  }

  .hero-sub {
    font-size: 1.05rem;
    color: rgba(239, 241, 238, 0.7);
    max-width: 46ch;
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--signal);
    color: var(--ink);
    padding: 14px 24px;
    border-radius: var(--radius);
    transition: filter 0.15s ease;
  }

  .btn-primary:hover {
    filter: brightness(1.08);
  }

  .btn-secondary {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--paper);
    padding: 14px 24px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius);
    transition: border-color 0.15s ease;
  }

  .btn-secondary:hover {
    border-color: var(--signal);
  }

  .hero-panel {
    background: var(--ink-soft);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    padding: 20px;
  }

  .panel-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(239, 241, 238, 0.45);
    margin-bottom: 14px;
  }

  .panel-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 10px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .dot-on {
    background: #6fbf73;
  }

  .dot-idle {
    background: var(--signal);
  }

  /* Directory */
  .directory {
    padding: 88px 0;
  }

  .directory h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin: 14px 0 40px;
  }

  .directory-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .module-card {
    position: relative;
    display: block;
    background: var(--paper-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 22px 20px 26px;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .module-card:hover {
    border-color: var(--signal);
    transform: translateY(-2px);
  }

  .module-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .module-code {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--signal);
  }

  .module-type {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--steel);
  }

  .module-name {
    font-size: 1.1rem;
    margin-bottom: 8px;
  }

  .module-desc {
    font-size: 0.88rem;
    color: var(--steel);
    line-height: 1.5;
    margin-bottom: 18px;
  }

  .module-arrow {
    font-family: var(--font-mono);
    color: var(--ink);
  }

  /* CTA band */
  .cta-band {
    background: var(--deep-blue);
    color: var(--paper);
  }

  .cta-inner {
    padding: 56px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .cta-inner h2 {
    color: var(--paper);
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    margin-top: 8px;
  }

  .cta-inner .eyebrow {
    color: var(--signal);
  }

  /* Footer */
  .site-footer {
    background: var(--ink);
    color: rgba(239, 241, 238, 0.6);
  }

  .footer-inner {
    padding: 24px 32px;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .footer-links a:hover {
    color: var(--signal);
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .directory-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .directory-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
