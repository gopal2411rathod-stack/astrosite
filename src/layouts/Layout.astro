---

import Navbar from "../components/Navbar.astro";
import "../styles/global.css";


interface Props {
  title?: string;
  description?: string;
}

const {
  title = "YourCompany - Retail & Service Software",
  description = "Software for automotive, autoparts, and hardware retail, plus Odoo and Shopify implementation services.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
  </body>
</html>
